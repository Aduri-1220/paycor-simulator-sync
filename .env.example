SOURCE_PATH=./data/employees.json
SOURCE_FORMAT=auto
DB_PATH=./data/payroll.db
SYNC_INTERVAL_MINUTES=10
MAX_RETRIES=3
RETRY_BASE_MS=500
SKIP_UNCHANGED=true
RUN_ON_START=true
LOG_LEVEL=info

# Document pipeline (Level 3)
DOCUMENTS_DIR=./data/documents
TEMPLATE_ID=time-off-approval
PDF_ENGINE=playwright
EMAIL_PROVIDER=resend
EMAIL_API_KEY=
EMAIL_FROM=onboarding@resend.dev
EMAIL_DRY_RUN=true

# CRM sync (Level 4)
CRM_MODE=mock
CRM_API_KEY=
CRM_BASE_URL=
CRM_HUBSPOT_PIPELINE=
CRM_HUBSPOT_DEALSTAGE=
CRM_HUBSPOT_PORTAL_ID=
CRM_MAX_JOB_RETRIES=5

# Web UI
UI_PORT=3001

# AI draft quotes (Level 5)
QUOTE_AI_MODE=mock
QUOTE_AI_MODEL=gpt-4o-mini
QUOTE_PROMPT_VERSION=quote-draft-v1
QUOTE_CATALOG_PATH=./config/catalog.json
QUOTE_PROMPT_PATH=./config/prompts/quote-draft-v1.json
OPENAI_API_KEY=

# Portal MCP server (Level 6)
MCP_API_KEY=
MCP_REQUIRE_AUTH=false
