SOURCE_PATH=./data/employees.json
SOURCE_FORMAT=auto
DB_PATH=./data/payroll.db
SYNC_INTERVAL_MINUTES=10
MAX_RETRIES=3
RETRY_BASE_MS=500
SKIP_UNCHANGED=true
RUN_ON_START=true
LOG_LEVEL=info

# Document pipeline (Level 3)
DOCUMENTS_DIR=./data/documents
TEMPLATE_ID=time-off-approval
PDF_ENGINE=playwright
EMAIL_PROVIDER=resend
EMAIL_API_KEY=
EMAIL_FROM=onboarding@resend.dev
EMAIL_DRY_RUN=true
